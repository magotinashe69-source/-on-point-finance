# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# then paste the result after SECRET_KEY= below.

SECRET_KEY=0872dd548bb663d3e75912b8ff4295d7d2a14707b1ab30dc62204ab1ba895db0

# Which config to use: "dev" while building, "prod" for the real app.
FLASK_CONFIG=dev

# Tells the flask CLI (used for migrations in Phase 2) where the app is.
FLASK_APP=run.py
